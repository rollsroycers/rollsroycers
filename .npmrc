# @opennextjs/cloudflare pins a strict `next` peer range (e.g. ~15.3.9) that the
# repo's pinned next@15.3.3 does not satisfy, so `npm ci` (npm v7+) fails with
# ERESOLVE on clean installs (Cloudflare Workers Builds, GitHub Actions, fresh
# clones, the publish-due cron). legacy-peer-deps installs the exact tree from
# package-lock.json — the same one that builds and runs locally — without npm
# trying to "fix" the peer by pulling an incompatible next@16.
legacy-peer-deps=true
